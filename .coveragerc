[run]
source = src/cybernetics_agent
omit = 
    */src/cybernetics_agent/adapters/*
    */src/cybernetics_agent/cli/audit.py
    */src/cybernetics_agent/cli/dashboard.py
    */src/cybernetics_agent/cli/dashboard_fastapi.py
    */src/cybernetics_agent/cli/init.py
    */src/cybernetics_agent/cli/main.py
    */src/cybernetics_agent/cli/plugin_cmd.py
    */src/cybernetics_agent/cli/preset.py
    */src/cybernetics_agent/cli/report.py
    */src/cybernetics_agent/cli/validate.py
    */src/cybernetics_agent/cli/alert_cmd.py
    */src/cybernetics_agent/cli/__main__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
